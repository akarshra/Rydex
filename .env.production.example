# Environment Variables for Production
# Copy this to your Vercel project environment variables

# Backend Configuration
NEXT_PUBLIC_BACKEND_URL=https://your-render-backend-url.onrender.com
NEXT_PUBLIC_APP_URL=https://your-vercel-frontend-url.vercel.app
NEXTAUTH_URL=https://your-vercel-frontend-url.vercel.app

# Database URLs (from Render)
MONGODB_URL=mongodb://your-mongo-connection-string
REDIS_URL=redis://your-redis-connection-string

# Socket Server
NEXT_PUBLIC_SOCKET_URL=https://your-render-socketserver-url.onrender.com

# Authentication
NEXTAUTH_SECRET=your-nextauth-secret-key
JWT_SECRET=your-jwt-secret-key

# Payment (Stripe)
STRIPE_PUBLISHABLE_KEY=pk_live_your_stripe_publishable_key
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key

# Cloud Storage (Cloudinary)
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# AI Services
OPENAI_API_KEY=your-openai-api-key
GOOGLE_AI_API_KEY=your-google-ai-api-key